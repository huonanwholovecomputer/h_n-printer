<!--me.wxml-->
<navigation-bar title="我" back="{{false}}" color="black" background="#FFF"></navigation-bar>

<view class="page-root {{pageSlide}} {{pageExit}}">
  <!-- 自定义滚动容器：负责橡皮筋回弹物理（与首页一致） -->
  <view
    class="scroller"
    bindtouchstart="onScrollerTouchStart"
    bindtouchmove="onScrollerTouchMove"
    bindtouchend="onScrollerTouchEnd"
    bindtouchcancel="onScrollerTouchEnd"
  >
    <view class="scroll-content" style="transform: translateY({{-scrollTop}}px);">
      <view class="container">

    <!-- 用户信息卡片 -->
    <view class="user-card ">
      <view class="avatar-btn" bindtap="onChooseAvatar" hover-class="avatar-hover">
        <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="user-info">
        <input class="nickname-input" type="nickname" value="{{nickname}}" bindinput="onNicknameInput" bindblur="onNicknameSave" placeholder="点击输入昵称" />
        <text class="uid">{{isSuperAdmin ? '超级管理员' : (userRole === 'admin' ? '管理员' : (userRole === 'user' ? '普通用户' : '访客'))}}</text>
      </view>
    </view>

    <!-- 角色入口：普通用户 → 我的统计（管理员/访客不显示） -->
    <view wx:if="{{userRole === 'user'}}" class="role-actions">
      <view class="role-btn user-btn" bindtap="onGoMyPerformance" hover-class="tap-active">
        <text class="role-btn-icon">📈</text>
        <text class="role-btn-text">我的统计</text>
        <text class="role-btn-arrow">›</text>
      </view>
    </view>

    <!-- 管理员：生成许可密钥 -->
    <view wx:if="{{userRole === 'admin'}}" class="license-section">
      <view class="section-title">
        <view class="section-bar"></view>
        <text>生成许可密钥</text>
      </view>
      <view class="license-card">
        <text class="license-label">有效时间（分钟）</text>
        <view class="stepper license-stepper">
          <view class="stepper-btn {{licenseMinutes <= 1 ? 'stepper-disabled' : ''}}" bindtap="onLicenseMinutesMinus" hover-class="stepper-hover" hover-stay-time="100">−</view>
          <input class="stepper-input" type="number" value="{{licenseMinutes}}" bindinput="onLicenseMinutesChange" />
          <view class="stepper-btn" bindtap="onLicenseMinutesPlus" hover-class="stepper-hover" hover-stay-time="100">+</view>
        </view>
        <!-- 超级管理员：许可密钥类型选择 -->
        <view wx:if="{{isSuperAdmin}}" class="key-type-row">
          <text class="key-type-label">密钥类型</text>
          <view class="key-type-toggle">
            <view class="key-type-option {{keyType === 'temp' ? 'key-type-active' : ''}}" bindtap="onSelectKeyType" data-type="temp" hover-class="tap-active">临时许可</view>
            <view class="key-type-option {{keyType === 'admin' ? 'key-type-active' : ''}}" bindtap="onSelectKeyType" data-type="admin" hover-class="tap-active">管理员许可</view>
          </view>
        </view>
        <button class="generate-btn" bindtap="onGenerateKey" hover-class="generate-hover" loading="{{generating}}" disabled="{{generating}}">生成许可密钥</button>
      </view>

      <!-- 活跃密钥列表（向下延伸排列，支持多个同时存在） -->
      <view wx:for="{{activeKeys}}" wx:key="key"
            class="key-drawer key-drawer-show {{item.expired && item.status === 'unused' ? 'key-drawer-expired' : ''}} {{item.status !== 'unused' ? 'key-drawer-locked' : ''}}">
        <!-- 右侧删除按钮（绝对定位，左滑时露出） -->
        <view class="key-delete" catchtap="onRevokeKey" data-idx="{{index}}"
              style="opacity: {{item.deleteOpacity}}">
          <text class="delete-icon">✕</text>
          <text>{{item.status === 'unused' ? '作废' : '删除'}}</text>
        </view>
        <!-- 卡片本体：可左滑 -->
        <view class="key-drawer-inner {{item.swipeTransition ? '' : 'no-transition'}}"
              style="transform: translateX({{item.swipeX}}px);"
              bindtouchstart="onKeyTouchStart"
              catchtouchmove="onKeyTouchMove"
              bindtouchend="onKeyTouchEnd"
              bindtouchcancel="onKeyTouchEnd"
              data-idx="{{index}}">
          <view class="key-row">
            <view class="key-left">
              <text class="key-label">{{item.type === 'admin' ? '管理员密钥' : '许可密钥'}}</text>
              <text class="key-value">{{item.key}}</text>
            </view>
            <view class="key-right">
              <text wx:if="{{item.status === 'unused'}}" class="key-countdown {{item.expired ? 'countdown-expired' : ''}}">{{item.countdownText}}</text>
              <text wx:else class="key-countdown">已使用</text>
            </view>
          </view>
          <!-- 兑换用户信息（used_waiting / used_done 时显示） -->
          <view wx:if="{{item.status !== 'unused'}}" class="key-user-info">
            <image wx:if="{{item.used_by_avatar_url}}" class="key-user-avatar" src="{{item.used_by_avatar_url}}" mode="aspectFill" />
            <text class="key-user-name">{{item.used_by_nickname}}</text>
          </view>
          <view class="key-actions">
            <!-- unused: 未过期可复制 -->
            <button wx:if="{{item.status === 'unused' && !item.expired}}" class="copy-btn" bindtap="onCopyKey" data-idx="{{index}}" hover-class="tap-active">复制</button>
            <!-- unused 已过期 -->
            <button wx:elif="{{item.status === 'unused' && item.expired}}" class="copy-btn copy-btn-disabled">已过期</button>
            <!-- used_waiting + admin: 确认并关闭 -->
            <button wx:elif="{{item.status === 'used_waiting' && item.type === 'admin'}}" class="copy-btn btn-confirm-admin" bindtap="onConfirmAdminKey" data-idx="{{index}}" hover-class="tap-active">确认并关闭</button>
            <!-- used_waiting + temp: 等待任务中 -->
            <button wx:elif="{{item.status === 'used_waiting' && item.type !== 'admin'}}" class="copy-btn btn-waiting" disabled>等待任务中</button>
            <!-- used_done: 结束打印任务 -->
            <button wx:elif="{{item.status === 'used_done'}}" class="copy-btn btn-end-task" bindtap="onEndPrintTask" data-idx="{{index}}" hover-class="tap-active">结束打印任务</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 访客：验证许可密钥 -->
    <view wx:if="{{userRole === 'guest'}}" class="license-section">
      <view class="section-title">
        <view class="section-bar"></view>
        <text>验证许可密钥</text>
      </view>
      <view class="license-card">
        <text class="redeem-desc">请输入管理员提供的许可密钥以获取打印权限</text>
        <view class="redeem-input-row">
          <input class="redeem-input" type="text" value="{{redeemKey}}" bindinput="onRedeemKeyInput" placeholder="请输入8位密钥" maxlength="8" />
          <button class="redeem-btn" bindtap="onRedeemKey" loading="{{redeeming}}" disabled="{{redeeming}}" hover-class="tap-active">验证</button>
        </view>
      </view>
    </view>

    <!-- 普通用户 / 临时授权：已获得许可 -->
    <view wx:if="{{userRole === 'user'}}" class="license-section">
      <view class="section-title">
        <view class="section-bar"></view>
        <text>打印许可</text>
      </view>
      <view class="license-card user-license-card">
        <view class="user-license-header">
          <text class="license-status-icon">✅</text>
          <text class="license-status-text">您已获得打印许可</text>
        </view>
        <view wx:if="{{licenseInfo}}" class="user-license-detail">
          <view class="license-detail-row">
            <text class="license-detail-label">许可密钥</text>
            <text class="license-detail-value license-key-value">{{licenseInfo.key}}</text>
          </view>
          <view class="license-detail-row">
            <text class="license-detail-label">授权人</text>
            <text class="license-detail-value">{{licenseInfo.creator_nickname}}</text>
          </view>
        </view>
        <text wx:if="{{tempCountdownText}}" class="temp-countdown">{{tempCountdownText}}</text>
      </view>
    </view>

    <!-- 管理员：存储统计 -->
    <view wx:if="{{userRole === 'admin' && storageStats}}" class="storage-section " style="animation-delay: 0.08s">
      <view class="section-title">
        <view class="section-bar"></view>
        <text>服务器存储</text>
      </view>
      <view class="storage-card">
        <view class="storage-row">
          <text class="storage-label">📄 缓存文件</text>
          <text class="storage-value">{{storageStats.total_files}} 个</text>
        </view>
        <view class="storage-row">
          <text class="storage-label">💾 占用空间</text>
          <text class="storage-value">{{storageStats.total_size_display}}</text>
        </view>
        <!-- 保留时间设置 -->
        <view class="storage-divider"></view>
        <text class="retention-title">文件保留时间</text>
        <text wx:if="{{retentionDays === 0 && retentionHours === 0}}" class="retention-forever-hint">当前为「永不过期」</text>
        <view class="retention-row">
          <view class="retention-stepper">
            <view class="retention-stepper-btn {{retentionDays <= 0 ? 'stepper-disabled' : ''}}" bindtap="onRetentionDaysMinus" hover-class="stepper-hover">−</view>
            <input class="retention-stepper-input" type="number" value="{{retentionDays}}" bindinput="onRetentionDaysChange" />
            <view class="retention-stepper-btn" bindtap="onRetentionDaysPlus" hover-class="stepper-hover">+</view>
          </view>
          <text class="retention-unit">天</text>
          <view class="retention-stepper">
            <view class="retention-stepper-btn {{retentionHours <= 0 ? 'stepper-disabled' : ''}}" bindtap="onRetentionHoursMinus" hover-class="stepper-hover">−</view>
            <input class="retention-stepper-input" type="number" value="{{retentionHours}}" bindinput="onRetentionHoursChange" />
            <view class="retention-stepper-btn" bindtap="onRetentionHoursPlus" hover-class="stepper-hover">+</view>
          </view>
          <text class="retention-unit">小时</text>
        </view>
        <button class="retention-save-btn" bindtap="onSaveRetention" loading="{{savingRetention}}" disabled="{{savingRetention}}" hover-class="tap-active">保存设置</button>
        <button class="delete-all-btn" bindtap="onDeleteAllFiles" loading="{{deletingAllFiles}}" disabled="{{deletingAllFiles}}" hover-class="tap-active">⚠️ 删除全部缓存文件</button>
      </view>
    </view>

    <!-- 管理员：许可用户列表 -->
    <view wx:if="{{userRole === 'admin'}}" class="users-section " style="animation-delay: 0.12s">
      <view class="section-title">
        <view class="section-bar"></view>
        <text>许可用户</text>
        <text wx:if="{{licensedUsers.length > 0}}" class="order-count">{{licensedUsers.length}}</text>
      </view>
      <!-- 用户列表 -->
      <view wx:for="{{licensedUsers}}" wx:key="openid" class="user-item">
        <image class="user-avatar" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="user-detail">
          <text class="user-nickname">{{item.nickname}}</text>
          <text wx:if="{{item.license_key}}" class="user-license-key">密钥: {{item.license_key}}</text>
          <text class="user-licensed-at">许可时间: {{item.licensed_at}}</text>
        </view>
      </view>
      <!-- 空状态 -->
      <view wx:if="{{licensedUsers.length === 0}}" class="license-card">
        <text class="redeem-desc" style="text-align:center;margin:0;">暂无许可用户，生成密钥分享给他人即可</text>
      </view>
    </view>

    <!-- 管理员/超级管理员：历史授权用户 -->
    <view wx:if="{{userRole === 'admin'}}" class="role-actions" style="animation-delay: 0.14s">
      <view class="role-btn user-btn" bindtap="onGoAuthorizedUsers" hover-class="tap-active">
        <text class="role-btn-icon">👥</text>
        <text class="role-btn-text">历史授权用户</text>
        <text class="role-btn-arrow">›</text>
      </view>
    </view>

    <!-- 管理员/超级管理员：本地打印任务 -->
    <view wx:if="{{userRole === 'admin' || isSuperAdmin}}" class="role-actions" style="animation-delay: 0.16s">
      <view class="role-btn user-btn" bindtap="onGoLocalOrders" hover-class="tap-active">
        <text class="role-btn-icon">🖨️</text>
        <text class="role-btn-text">本地打印任务</text>
        <text class="role-btn-arrow">›</text>
      </view>
    </view>

    <!-- 超级管理员：管理员列表 -->
    <view wx:if="{{isSuperAdmin}}" class="license-section" style="animation-delay: 0.18s">
      <view class="section-title">
        <view class="section-bar"></view>
        <text>管理管理员</text>
        <text wx:if="{{admins.length > 0}}" class="order-count">{{admins.length}}</text>
      </view>
      <view wx:if="{{admins.length === 0 && !adminsLoading}}" class="license-card">
        <text class="redeem-desc" style="text-align:center;margin:0;">暂无其他管理员</text>
      </view>
      <view wx:for="{{admins}}" wx:key="openid" class="admin-card-wrap">
        <!-- 右侧删除按钮 -->
        <view class="admin-delete" catchtap="onRemoveAdmin" data-openid="{{item.openid}}"
              style="opacity: {{adminDeleteOpacity[item.openid] || 0}}">
          <text class="delete-icon">🗑</text>
          <text>移除</text>
        </view>
        <!-- 卡片本体：可左滑 -->
        <view class="admin-card {{adminSwipeTransition[item.openid] === false ? 'no-transition' : ''}}"
              style="transform: translateX({{adminSwipeX[item.openid] || 0}}px); transition: {{adminSwipeTransition[item.openid] === false ? 'none' : 'transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)'}};"
              bindtouchstart="onAdminTouchStart"
              bindtouchmove="onAdminTouchMove"
              bindtouchend="onAdminTouchEnd"
              bindtouchcancel="onAdminTouchEnd"
              data-openid="{{item.openid}}">
          <image wx:if="{{item.avatar_url}}" class="admin-avatar" src="{{item.avatar_url}}" mode="aspectFill" />
          <view wx:else class="admin-avatar admin-avatar-placeholder"></view>
          <view class="admin-info">
            <text class="admin-name">{{item.nickname}}</text>
            <text wx:if="{{item.is_super}}" class="admin-badge">超级管理员</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 我的打印任务 -->
    <view class="orders-section " style="animation-delay: 0.1s">
      <view class="section-title">
        <view class="section-bar"></view>
        <text>我的打印任务</text>
        <text wx:if="{{orders.length > 0}}" class="order-count">{{ordersTotal || orders.length}}</text>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{loading}}" class="status-box">
        <text class="status-text">加载中...</text>
      </view>

      <!-- 空状态 -->
      <view wx:elif="{{orders.length === 0}}" class="empty-state">
        <view class="empty-illustration">
          <text class="empty-icon">📋</text>
        </view>
        <text class="empty-title">暂无任务</text>
        <text class="empty-desc">快去打印你的第一份文件吧</text>
      </view>

      <!-- 分页控制栏（顶部） -->
      <view class="orders-pagination-bar" wx:if="{{ordersTotalPages > 0}}">
        <view class="page-size-selector" bindtap="onToggleOrdersPageSize">
          <text class="page-size-text">{{ordersPerPage}}条/页</text>
          <text class="page-size-arrow {{showPageSizePicker ? 'arrow-up' : ''}}">▼</text>
          <view class="page-size-dropdown {{showPageSizePicker ? 'dropdown-show' : ''}}" wx:if="{{showPageSizePicker}}">
            <view wx:for="{{pageOptions}}" wx:key="*this"
                  class="page-size-option {{ordersPerPage === item ? 'option-active' : ''}}"
                  catchtap="onSelectOrdersPageSize" data-size="{{item}}">
              {{item}} 条/页
            </view>
          </view>
        </view>
        <view class="page-nav">
          <view class="page-btn {{ordersCurrentPage <= 1 ? 'page-btn-disabled' : ''}}"
                bindtap="onOrdersPrevPage" hover-class="tap-active">‹</view>
          <block wx:for="{{getOrdersPageNumbers()}}" wx:key="*this">
            <view wx:if="{{item === '...'}}" class="page-ellipsis">…</view>
            <view wx:else
                  class="page-num {{ordersCurrentPage === item ? 'page-num-active' : ''}}"
                  bindtap="onOrdersPageChange" data-page="{{item}}" hover-class="tap-active">{{item}}</view>
          </block>
          <view class="page-btn {{ordersCurrentPage >= ordersTotalPages ? 'page-btn-disabled' : ''}}"
                bindtap="onOrdersNextPage" hover-class="tap-active">›</view>
        </view>
      </view>

      <!-- 任务列表 -->
      <view wx:for="{{orders}}" wx:key="id"
            class="order-card {{expandedOrders[item.id] ? 'order-expanded' : ''}}"
            bindtap="onOrderTap" data-id="{{item.id}}">
        <!-- 收缩态：一行摘要 -->
        <view class="order-card-header">
          <view class="order-card-main">
            <text class="order-filename">{{item.order_number || ('#' + item.id)}}</text>
            <text class="order-status status-{{item.status}} {{item.isExcel && item.status === 'sent' ? 'status-delivered' : ''}}">{{item.isExcel && item.status === 'sent' ? '已送达' : (statusMap[item.status] || item.status)}}</text>
          </view>
          <text class="order-number-label">{{item.file_summary || item.file}}</text>
          <view wx:if="{{item.isExcel}}" class="order-card-meta">
            <text class="order-card-stat">📄 不适用</text>
            <text class="order-card-stat">📋 不适用</text>
          </view>
          <view wx:else class="order-card-meta">
            <text class="order-card-stat">📄 {{item.total_pages || (item.page_count * item.copies)}} 页</text>
            <text class="order-card-stat">📋 {{item.total_copies || item.copies}} 份 · {{item.duplex === 'on' ? '双面' : '单面'}}</text>
          </view>
          <view class="order-card-footer">
            <text class="order-created">{{item.created_at}}</text>
            <text class="order-arrow {{expandedOrders[item.id] ? 'arrow-up' : ''}}">›</text>
          </view>
        </view>

        <!-- 展开态：详细信息 -->
        <view class="order-card-detail {{expandedOrders[item.id] ? 'detail-expanded' : ''}}">
          <view class="detail-divider"></view>

          <!-- 打印信息 -->
          <view class="detail-section">
            <view class="detail-section-title">打印信息</view>
            <view class="detail-row">
              <text class="detail-label">提交时间</text>
              <text class="detail-value">{{item.created_at}}</text>
            </view>
            <view wx:if="{{!item.isExcel}}" class="detail-row">
              <text class="detail-label">打印模式</text>
              <text class="detail-value">{{item.duplex === 'on' ? '双面' : '单面'}}</text>
            </view>
            <view class="detail-row">
              <text class="detail-label">合计页数</text>
              <text class="detail-value">{{item.isExcel ? '不适用' : (item.total_pages || (item.page_count * item.copies)) + ' 页'}}</text>
            </view>
            <view class="detail-row">
              <text class="detail-label">合计份数</text>
              <text class="detail-value">{{item.isExcel ? '不适用' : (item.total_copies || item.copies) + ' 份'}}</text>
            </view>
          </view>

          <!-- 文件列表 -->
          <view wx:if="{{item.files && item.files.length > 0}}" class="detail-section">
            <view class="detail-section-title">文件列表 ({{item.files.length}})</view>
            <view wx:for="{{item.files}}" wx:for-item="f" wx:key="id" class="detail-file-row">
              <view class="detail-file-info">
                <text class="detail-file-name">{{f.original_name || f.file_name}}</text>
                <view class="detail-file-tags">
                  <text wx:if="{{f.file_type}}" class="file-type-tag">{{f.file_type}}</text>
                  <text wx:if="{{f.sizeDisplay}}" class="file-size-tag">{{f.sizeDisplay}}</text>
                </view>
              </view>
              <view class="detail-file-right">
                <text class="detail-file-copies">{{f.copies}} 份 × {{f.page_count}} 页</text>
                <text wx:if="{{f.page_range}}" class="detail-file-range">范围: {{f.page_range}}</text>
                <text class="file-status-mini status-{{f.status}}">{{statusMap[f.status] || f.status}}</text>
              </view>
            </view>
          </view>

          <!-- 操作按钮 -->
          <view class="detail-actions">
            <button wx:if="{{item.status === 'queued' || item.status === 'printing'}}"
                    class="btn-cancel-sm" catchtap="onDetailCancelOrder" data-id="{{item.id}}">取消任务</button>
          </view>
        </view>
      </view>

      <!-- 底部分页 + 结束提示 -->
      <view class="orders-pagination-bar pagination-bottom" wx:if="{{ordersTotalPages > 1}}">
        <view class="page-nav">
          <view class="page-btn {{ordersCurrentPage <= 1 ? 'page-btn-disabled' : ''}}"
                bindtap="onOrdersPrevPage" hover-class="tap-active">‹</view>
          <block wx:for="{{getOrdersPageNumbers()}}" wx:key="*this">
            <view wx:if="{{item === '...'}}" class="page-ellipsis">…</view>
            <view wx:else
                  class="page-num {{ordersCurrentPage === item ? 'page-num-active' : ''}}"
                  bindtap="onOrdersPageChange" data-page="{{item}}" hover-class="tap-active">{{item}}</view>
          </block>
          <view class="page-btn {{ordersCurrentPage >= ordersTotalPages ? 'page-btn-disabled' : ''}}"
                bindtap="onOrdersNextPage" hover-class="tap-active">›</view>
        </view>
      </view>

      <view wx:if="{{ordersCurrentPage >= ordersTotalPages && ordersTotalPages > 0 && orders.length > 0}}" class="end-hint">
        <text class="end-hint-text">-- 没有更多内容啦 --</text>
      </view>

    </view>
    </view>
  </view>
</view>
</view>