/* Apple-style Performance Page (Monthly Stats) */

.container {
  padding: 24rpx 32rpx;
  padding-bottom: 40rpx;
}

/* ── Date Picker ── */
.date-picker {
  display: flex;
  justify-content: space-around;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 20rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-sm);
}

.picker-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.picker-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--blue);
  padding: 8rpx 28rpx;
  background: rgba(0, 122, 255, 0.06);
  border-radius: var(--radius-md);
}

/* ── Status ── */
.status-box {
  text-align: center;
  padding: 60rpx;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

/* ── Stats Grid ── */
.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.card-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--blue);
  margin-bottom: 8rpx;
  font-family: var(--font-mono);
  letter-spacing: -0.02em;
}

.card-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* ── Empty State ── */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 26rpx;
  color: var(--text-tertiary);
}
