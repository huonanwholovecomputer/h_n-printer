<!-- Apple-style Index Page — 提交打印 -->
<navigation-bar title="提交打印" back="{{false}}" color="black" background="#FFF"></navigation-bar>

<view class="page-root {{pageSlide}} {{pageExit}}">
  <view
    class="scroller"
    bindtouchstart="onScrollerTouchStart"
    bindtouchmove="onScrollerTouchMove"
    bindtouchend="onScrollerTouchEnd"
    bindtouchcancel="onScrollerTouchEnd"
  >
    <view class="scroll-content" style="transform: translateY({{-scrollTop}}px);">
      <view class="container">

        <!-- Logo + Status -->
        <view class="header-area" style="padding-top: {{logoPadding}}rpx; padding-bottom: {{logoPadding}}rpx;">
          <view class="logo-wrap" style="transform: scale({{logoScale}}); transform-origin: center top;">
            <image class="logo" src="/images/HN_print.png" mode="widthFix" style="width: 320rpx;" />
          </view>
        </view>

        <!-- Printer Status -->
        <view class="status-bar {{printerActive ? 'status-active' : 'status-inactive'}} {{pageReady ? 'card-entering' : 'card-preload'}}">
          <view class="status-dot"></view>
          <text class="status-text">{{printerActive ? '打印机在线' : '打印机离线'}}</text>
        </view>

        <!-- File List Section -->
        <view class="card file-section {{pageReady ? 'card-entering' : 'card-preload'}}">
          <view class="section-header inline-header">
            <view class="section-header-bar"></view>
            <text class="section-header-title">打印文件</text>
            <text wx:if="{{badgeCount > 0 || badgeExiting}}" class="section-header-badge {{badgeEntering ? 'entering' : ''}} {{badgeBouncing ? 'bouncing' : ''}} {{badgeExiting ? 'exiting' : ''}}">{{badgeCount || 1}}</text>
          </view>

          <!-- File Cards -->
          <view
            wx:for="{{selectedFiles}}"
            wx:key="index"
            class="file-card {{item.entering ? 'card-entering' : ''}} {{item.removing ? 'card-removing' : ''}}"
          >
            <!-- Header: name + remove -->
            <view class="file-card-top">
              <view class="file-name-area">
                <text class="file-name">{{item.name}}</text>
                <text class="file-size">{{item.sizeDisplay}} KB</text>
              </view>
              <view class="file-remove" bindtap="onRemoveFile" data-index="{{index}}" hover-class="tap-active">✕</view>
            </view>

            <!-- Upload Status -->
            <view class="file-status-area">
              <block wx:if="{{item.uploading}}">
                <view class="upload-row">
                  <text class="status-label uploading">上传中…</text>
                  <text class="upload-pct">{{item.progress}}%</text>
                </view>
                <view class="progress-track">
                  <view class="progress-fill" style="width: {{item.progress}}%;"></view>
                </view>
              </block>
              <block wx:elif="{{item.failed}}">
                <text class="status-label failed">上传失败</text>
              </block>
              <block wx:elif="{{item.fileId && item.excelWarning}}">
                <text class="status-label warn">Excel 不支持自动打印，请联系管理员</text>
              </block>
              <block wx:elif="{{item.fileId && item.unsupportedFormat}}">
                <text class="status-label warn">该文件格式不支持自动打印，请联系管理员</text>
              </block>
              <block wx:elif="{{item.fileId}}">
                <text class="status-label done">已上传</text>
                <!-- 页数分析进度（非图片/Excel 文件）-->
                <view wx:if="{{!item.isImage && !item.excelWarning && !item.unsupportedFormat && item.pageCountStatus === 'analyzing'}}" class="page-analysis-bar">
                  <view class="analysis-dot-pulse"></view>
                  <text class="analysis-text">正在分析页数，本地打印工具转换中…</text>
                </view>
                <view wx:elif="{{!item.isImage && !item.excelWarning && !item.unsupportedFormat && item.pageCountStatus === 'offline'}}" class="page-analysis-bar offline">
                  <text class="analysis-dot-warn">⚠</text>
                  <text class="analysis-text">本地打印工具离线，无法返回总页数</text>
                </view>
                <view wx:elif="{{!item.isImage && !item.excelWarning && !item.unsupportedFormat && item.pageCountStatus === 'confirmed' && item.pageCount > 0}}" class="page-analysis-bar confirmed">
                  <text class="analysis-dot-done">✓</text>
                  <text class="analysis-text">共 {{item.pageCount}} 页</text>
                </view>
              </block>
            </view>

            <!-- Per-file controls (uploaded only) -->
            <view wx:if="{{item.fileId && !item.excelWarning && !item.unsupportedFormat}}" class="file-controls">

              <!-- Copies stepper -->
              <view class="control-row">
                <text class="control-label">份数</text>
                <view class="stepper">
                  <view class="stepper-btn {{item.copies <= 1 ? 'stepper-disabled' : ''}}" bindtap="onFileCopiesMinus" data-index="{{index}}" hover-class="tap-active">−</view>
                  <input class="stepper-input" type="number" value="{{item.copies}}" bindinput="onFileCopiesChange" data-index="{{index}}" />
                  <view class="stepper-btn" bindtap="onFileCopiesPlus" data-index="{{index}}" hover-class="tap-active">+</view>
                </view>
              </view>

              <!-- Page range — multi-line (hidden for images, aligns with local tool RangeListWidget) -->
              <view wx:if="{{!item.isImage}}" class="control-row range-control-multi">
                <text class="control-label">范围</text>
                <view class="range-lines-wrap">
                  <view wx:for="{{item.rangeLines}}" wx:for-item="line" wx:for-index="li" wx:key="li" class="range-line-row">
                    <input
                      class="input-ios range-line-input {{line.error ? 'range-input-err' : ''}}"
                      type="text"
                      value="{{line.value}}"
                      placeholder="{{li === 0 ? '如 1-5 或 7' : ''}}"
                      bindinput="onRangeLineInput"
                      bindblur="onRangeLineBlur"
                      data-file-index="{{index}}"
                      data-line-index="{{li}}"
                    />
                    <text wx:if="{{line.error}}" class="range-err-msg range-line-err">{{line.error}}</text>
                  </view>
                </view>
              </view>

              <!-- Duplex toggle -->
              <view class="control-row">
                <text class="control-label">模式</text>
                <view class="duplex-toggle">
                  <view class="duplex-slider {{item.duplex === 'on' ? 'slider-right' : ''}}"></view>
                  <view class="duplex-opt {{item.duplex === 'off' ? 'opt-active' : ''}}" bindtap="onFileDuplexChange" data-index="{{index}}" data-value="off">单面</view>
                  <view class="duplex-opt {{item.duplex === 'on' ? 'opt-active' : ''}}" bindtap="onFileDuplexChange" data-index="{{index}}" data-value="on">双面</view>
                </view>
              </view>
            </view>
          </view>

          <!-- Add file button -->
          <button class="add-file-btn {{btnPulse ? 'pulsing' : ''}}" bindtap="onChooseFile" hover-class="tap-active">
            <text class="add-icon">+</text>
            <text>{{selectedFiles.length ? '添加文件' : '选择打印文件'}}</text>
          </button>
        </view>

        <!-- v5: 附加服务参数 -->
        <view class="card ext-params-card {{pageReady ? 'card-entering' : 'card-preload'}}" style="animation-delay: 0.15s">
          <view class="section-header inline-header">
            <view class="section-header-bar"></view>
            <text class="section-header-title">附加服务</text>
          </view>

          <!-- 派送开关 -->
          <view class="param-row">
            <text class="param-label">派送</text>
            <view class="ios-switch {{deliveryEnabled ? 'switch-on' : ''}}" bindtap="onToggleDelivery">
              <view class="switch-thumb"></view>
            </view>
          </view>

          <!-- 派送地点（派送开启时显示）-->
          <view class="delivery-collapse {{deliveryEnabled ? 'delivery-open' : ''}}">
            <view class="param-row">
              <text class="param-label">地点</text>
              <view class="picker-trigger" bindtap="onToggleDeliveryPicker">
                <text>{{deliveryLocation}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </view>
          </view>
          <view class="picker-sheet {{showDeliveryPicker ? 'picker-expanded' : ''}}">
            <view wx:for="{{deliveryLocations}}" wx:key="*this" class="picker-option {{deliveryLocation === item ? 'picker-selected' : ''}}" bindtap="onSelectDeliveryLocation" data-loc="{{item}}">
              <text>{{item}}</text>
              <text class="picker-pct">{{deliveryPercentages[item]}}%</text>
            </view>
          </view>

          <!-- 紧急程度 -->
          <view class="param-row">
            <text class="param-label">优先级</text>
            <view class="picker-trigger" bindtap="onToggleUrgencyPicker">
              <text class="{{urgency === '高' ? 'urgency-high' : urgency === '中' ? 'urgency-mid' : ''}}">{{urgency}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </view>
          <view class="picker-sheet {{showUrgencyPicker ? 'picker-expanded' : ''}}">
            <view wx:for="{{urgencyOptions}}" wx:key="*this" class="picker-option {{urgency === item ? 'picker-selected' : ''}}" bindtap="onSelectUrgency" data-urg="{{item}}">
              <text>{{item}}</text>
              <text class="picker-pct">¥{{urgencyPrices[item]}}</text>
            </view>
          </view>

          <!-- 打印首页 -->
          <view class="param-row">
            <text class="param-label">打印首页</text>
            <view class="ios-switch {{coverPage ? 'switch-on' : ''}}" bindtap="onToggleCoverPage">
              <view class="switch-thumb"></view>
            </view>
            <text wx:if="{{coverPriceVisible || coverPriceExiting}}" class="cover-price-tag {{coverPriceEntering ? 'entering' : ''}} {{coverPriceExiting ? 'exiting' : ''}}">¥{{coverPagePrice}}</text>
          </view>

          <!-- 自取地址（未派送时显示，带展开/收起动画）-->
          <view class="pickup-collapse {{!deliveryEnabled ? 'pickup-open' : ''}}">
            <view class="param-row">
              <text class="param-label">自取地址</text>
              <input class="control-input" value="{{pickupAddress}}" bindinput="onPickupAddressInput" placeholder="如 1号楼202宿舍" />
            </view>
          </view>
        </view>

        <!-- 无障碍打印开关（仅管理员可见） -->
        <view wx:if="{{userRole === 'admin'}}" class="auto-print-switch-row {{pageReady ? 'card-entering' : 'card-preload'}}" style="animation-delay: 0.18s">
          <view class="auto-print-label">
            <view class="lightning-burst {{autoPrintGlow ? 'striking' : ''}} {{glowPhase === 'fading' ? 'fading' : ''}} {{glowPhase === 'reset' ? 'reset' : ''}} {{autoPrintEnabled ? 'active' : ''}}">
              <canvas type="2d" id="boltCanvas" class="bolt-canvas"></canvas>
              <text class="auto-print-icon" style="{{glowStyle}}">⚡</text>
            </view>
            <text class="auto-print-title">无障碍打印</text>
            <text class="auto-print-desc">提交后自动开始打印，无需手动确认</text>
          </view>
          <view class="ios-switch ios-switch-lg {{autoPrintEnabled ? 'switch-on' : ''}}" bindtap="onAutoPrintToggle">
            <view class="switch-thumb"></view>
          </view>
        </view>

        <!-- Submit Button -->
        <view class="submit-area {{pageReady ? 'card-entering' : 'card-preload'}}" style="animation-delay: 0.2s">
          <button class="btn-primary" bindtap="onSubmit" hover-class="tap-active" loading="{{submitting}}" disabled="{{submitting}}">
            提交打印任务
          </button>
        </view>

      </view>
    </view>
  </view>
</view>

<!-- Page Count Warning Modal -->
<view wx:if="{{showPageCountWarning}}" class="modal-mask">
  <view class="modal-sheet" catchtap="noop">
    <view class="modal-icon-wrap" style="background-color: rgba(255, 149, 0, 0.1); color: #FF9500;">⚠</view>
    <text class="title-medium" style="margin-bottom: 8rpx;">页数未经验证</text>
    <text class="body-small" style="margin-bottom: 6rpx;">部分文档的页数尚未经本地打印工具确认，</text>
    <text class="body-small">页码范围可能超出文档实际页数。</text>
    <view class="modal-buttons">
      <button class="btn-secondary modal-half-btn" bindtap="onCancelForceSubmit" hover-class="tap-active">返回等待</button>
      <button class="btn-primary modal-half-btn" style="background-color: #FF9500;" bindtap="onConfirmForceSubmit" hover-class="tap-active">继续提交</button>
    </view>
  </view>
</view>

<!-- Success Modal -->
<view wx:if="{{showSuccessModal}}" class="modal-mask" bindtap="onCloseModal">
  <view class="modal-sheet" catchtap="noop">
    <view class="modal-icon-wrap">✓</view>
    <text class="title-medium" style="margin-bottom: 8rpx;">任务提交成功</text>
    <text wx:if="{{lastOrderNumber}}" class="order-number-modal">{{lastOrderNumber}}</text>
    <text class="body-small">文件已上传，打印任务已创建</text>
    <view class="modal-buttons">
      <button class="btn-secondary modal-half-btn" bindtap="onCopyPrice" hover-class="tap-active">复制价格</button>
      <button class="btn-primary modal-half-btn" bindtap="onCopyDetailPrice" hover-class="tap-active">复制详细价格</button>
    </view>
  </view>
</view>

<!-- Access Denied Modal -->
<view wx:if="{{showAccessDeniedModal}}" class="modal-mask" bindtap="onAccessDeniedConfirm">
  <view class="modal-sheet" catchtap="noop">
    <view class="modal-icon-wrap" style="background-color: rgba(255, 59, 48, 0.1); color: var(--red);">!</view>
    <text class="title-medium" style="margin-bottom: 8rpx;">需要许可</text>
    <text class="body-small">请先出示管理员许可</text>
    <view class="modal-buttons">
      <button class="btn-primary" bindtap="onAccessDeniedConfirm" hover-class="tap-active">前往获取</button>
    </view>
  </view>
</view>
