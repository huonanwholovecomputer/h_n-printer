/** Apple-style Index Page Styles **/

/* ── Root & Container ── */
.page-root {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: var(--bg-primary);
  min-height: 0;
}

/* 初始隐藏态：防止页面首次渲染时闪烁 */
.page-init {
  opacity: 0;
  pointer-events: none;
}

/* 入场：从左滑入 + 淡入 */
.page-enter-left {
  animation: enterLeft 0.3s 0.06s cubic-bezier(0.22, 0.61, 0.36, 1) both;
}
@keyframes enterLeft {
  from { opacity: 0; transform: translateX(-260rpx); }
  to   { opacity: 1; transform: translateX(0); }
}
/* 首次加载淡入 */
.page-fade-in {
  animation: fadeIn 0.3s 0.08s ease both;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* 退出动画：左滑淡出 */
.page-exit-left {
  animation: exitLeft 0.22s ease-in both;
}
@keyframes exitLeft {
  from { opacity: 1; transform: translateX(0); }
  to   { opacity: 0; transform: translateX(-260rpx); }
}
.page-exit-right {
  animation: exitRight 0.22s ease-in both;
}
@keyframes exitRight {
  from { opacity: 1; transform: translateX(0); }
  to   { opacity: 0; transform: translateX(260rpx); }
}

.scroller {
  flex: 1;
  overflow: hidden;
  position: relative;
  min-height: 0;
}

.scroll-content {
  will-change: transform;
}

.container {
  padding: 24rpx 32rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ── Header: Logo ── */
.header-area {
  text-align: center;
  padding: 32rpx 0;
  transition: padding 0.06s linear;
}

.logo-wrap {
  display: inline-block;
  transition: transform 0.06s linear;
}

.logo {
  width: 320rpx;
}

/* ── Printer Status ── */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 28rpx;
  gap: 10rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.status-active .status-dot {
  background-color: var(--green);
  animation: statusPulse 2s infinite;
}

.status-inactive .status-dot {
  background-color: var(--gray3);
}

.status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.status-active .status-text { color: var(--green); }
.status-inactive .status-text { color: var(--gray); }

/* ── File Section ── */
.file-section {
  margin-bottom: 20rpx;
}

.inline-header {
  padding: 0 0 20rpx 0;
  border-bottom: 0.5px solid var(--separator);
  margin-bottom: 20rpx;
}

/* ── File Cards ── */
.file-card {
  background-color: var(--gray6);
  border-radius: var(--radius-md);
  padding: 20rpx 22rpx;
  margin-bottom: 12rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.file-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.file-name-area {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.file-remove {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.5);
  color: var(--text-tertiary);
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  transition: transform 0.1s ease, background-color 0.15s ease, color 0.15s ease;
}

.file-remove:active {
  transform: scale(0.92);
  background-color: var(--red);
  color: #fff;
  border-color: var(--red);
  box-shadow: none;
}

/* Upload Status */
.file-status-area {
  margin-top: 14rpx;
  min-height: 28rpx;
}

.status-label {
  font-size: 22rpx;
  font-weight: 500;
}
.status-label.uploading { color: var(--blue); }
.status-label.done      { color: var(--green); }
.status-label.failed    { color: var(--red); }
.status-label.warn      { color: var(--orange); font-size: 20rpx; }

.upload-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.upload-pct {
  font-size: 22rpx;
  font-family: var(--font-mono);
  color: var(--blue);
}

/* Progress bar */
.progress-track {
  width: 100%;
  height: 8rpx;
  background-color: rgba(60, 60, 67, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: var(--blue);
  border-radius: 4rpx;
  transition: width 0.4s ease-out;
}

/* ── File Controls (per-file) ── */
.file-controls {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 0.5px solid var(--separator);
}

.control-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  gap: 14rpx;
}
.control-row:last-child {
  margin-bottom: 0;
}

.control-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  width: 56rpx;
  flex-shrink: 0;
}

.range-control-row {
  align-items: flex-start;
}
/* 多行范围输入（对齐本地工具 RangeListWidget） */
.range-control-multi {
  align-items: flex-start;
}
.range-lines-wrap {
  flex: 1;
  min-width: 0;
}
.range-line-row {
  margin-bottom: 4rpx;
}
.range-line-input {
  height: 56rpx;
  font-size: 24rpx;
  padding: 0 14rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--gray4);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
}
.range-line-input.range-input-err {
  border-color: var(--red);
  background-color: rgba(255, 59, 48, 0.05);
}
.range-line-err {
  display: block;
  font-size: 20rpx;
  color: var(--red);
  margin-top: 4rpx;
  padding-left: 4rpx;
  line-height: 1.4;
}

/* ── 页数分析进度条 ── */
.page-analysis-bar {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #FFFFFF;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--gray4);
}
.page-analysis-bar.confirmed {
  border-color: var(--green);
  background: rgba(52, 199, 89, 0.06);
}
.page-analysis-bar.offline {
  border-color: #FF9500;
  background: rgba(255, 149, 0, 0.06);
}
.analysis-dot-pulse {
  width: 14rpx;
  height: 14rpx;
  border-radius: 7rpx;
  background: #007AFF;
  margin-right: 10rpx;
  flex-shrink: 0;
  animation: analysisPulse 1.2s ease-in-out infinite;
}
@keyframes analysisPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}
.analysis-dot-done {
  font-size: 22rpx;
  color: var(--green);
  margin-right: 10rpx;
  flex-shrink: 0;
}
.analysis-dot-warn {
  font-size: 22rpx;
  color: #FF9500;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.analysis-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.3;
}

/* 旧版单行样式保留兼容 */
.range-input-wrap {
  flex: 1;
  min-width: 0;
}
.range-input {
  height: 56rpx;
  font-size: 24rpx;
  padding: 0 14rpx;
}
.range-input.range-input-err {
  border-color: var(--red);
  background-color: rgba(255, 59, 48, 0.05);
}
.range-err-msg {
  display: block;
  font-size: 20rpx;
  color: var(--red);
  margin-top: 6rpx;
  line-height: 1.4;
}

/* ── Duplex Toggle (per-file, compact) ── */
.duplex-toggle {
  flex: 1;
  position: relative;
  display: flex;
  border-radius: 14rpx;
  overflow: hidden;
  background-color: rgba(60, 60, 67, 0.08);
  height: 56rpx;
}

.duplex-slider {
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  width: calc(50% - 3rpx);
  height: calc(100% - 6rpx);
  border-radius: 12rpx;
  background: linear-gradient(180deg,
    rgba(0, 122, 255, 0.88) 0%,
    rgba(0, 105, 220, 0.94) 100%);
  box-shadow:
    0 2rpx 8rpx rgba(0, 122, 255, 0.25),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  z-index: 0;
}

.duplex-slider.slider-right {
  transform: translateX(100%);
}

.duplex-opt {
  flex: 1;
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: color 0.25s ease;
}

.duplex-opt.opt-active {
  color: #fff;
  font-weight: 600;
}

/* ── Add File Button ── */
.add-file-btn {
  width: 100%;
  background: rgba(255, 255, 255, 0.45);
  color: var(--blue);
  font-size: 28rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  padding: 22rpx;
  text-align: center;
  border: 2rpx dashed rgba(0, 122, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  transition: transform 0.12s cubic-bezier(0.4, 0, 0.2, 1),
              background-color 0.12s ease;
}
.add-file-btn.pulsing {
  animation: btnPulse 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes btnPulse {
  0%   { transform: scale(1); }
  35%  { transform: scale(0.96); }
  70%  { transform: scale(1.015); }
  100% { transform: scale(1); }
}
.add-file-btn:active {
  transform: scale(0.97);
  background-color: rgba(0, 122, 255, 0.12);
}

.add-icon {
  font-size: 30rpx;
  font-weight: 300;
  line-height: 1;
}

/* ── Submit ── */
/* ── 无障碍打印开关（仅管理员可见）── */
.auto-print-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 149, 0, 0.06);
  border: 1rpx solid rgba(255, 149, 0, 0.2);
  border-radius: var(--radius-md);
}
.auto-print-label {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
/* ── ⚡ 闪电图标 + Canvas 电流射线 ── */
.lightning-burst {
  position: relative;
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
}
.bolt-canvas {
  position: absolute;
  top: 50%; left: 50%;
  width: 240rpx;
  height: 240rpx;
  margin-left: -120rpx;
  margin-top: -120rpx;
  pointer-events: none;
  background: transparent;
  border: none;
  outline: none;
}
.auto-print-icon {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  z-index: 1;
}

/* 浮动动画（无障碍打印开启期间常驻，无光晕） */
.lightning-burst.active .auto-print-icon {
  animation: iconFloat 3s ease-in-out infinite;
}
/* 闪电爆发瞬间：闪白 + 抖动 */
.lightning-burst.striking .auto-print-icon {
  animation: iconFlash 0.5s ease-out, iconShake 0.3s 0.02s ease-out;
}
/* JS 渐隐完成后强制复位（打断任何残留的 GPU 合成层） */
.lightning-burst.reset .auto-print-icon {
  animation: none !important;
}
/* 环形冲击波 */
.lightning-burst::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 0; height: 0;
  border: 2rpx solid rgba(255, 230, 0, 0);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}
.lightning-burst.striking::before {
  animation: shockRing 0.5s 0.02s ease-out forwards;
}

@keyframes iconFlash {
  0%   { text-shadow: 0 0 0 #fff; }
  15%  { text-shadow: 0 0 30rpx #fff, 0 0 12rpx #ffe500; }
  100% { text-shadow: 0 0 0 #fff; }
}
@keyframes iconShake {
  0%   { margin-left: 0;    margin-top: 0; }
  10%  { margin-left: 3rpx; margin-top: -2rpx; }
  20%  { margin-left: -3rpx; margin-top: 1rpx; }
  30%  { margin-left: 2rpx; margin-top: 2rpx; }
  40%  { margin-left: -2rpx; margin-top: -1rpx; }
  50%  { margin-left: 1rpx; margin-top: -1rpx; }
  70%  { margin-left: -1rpx; margin-top: 1rpx; }
  100% { margin-left: 0;    margin-top: 0; }
}
@keyframes shockRing {
  0%   { width: 4rpx; height: 4rpx; border-color: rgba(255,230,0,0.8); border-width: 3rpx; }
  100% { width: 90rpx; height: 90rpx; border-color: rgba(255,200,0,0); border-width: 1rpx; }
}
@keyframes iconFloat {
  0%, 100% { transform: translate(-50%, -50%); }
  50%      { transform: translate(-50%, calc(-50% - 4rpx)); }
}
.auto-print-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF9500;
}
.auto-print-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.submit-area {
  padding: 16rpx 0;
}

/* ── Success Modal ── */
.order-number-modal {
  font-family: var(--font-mono);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--blue);
  background: rgba(0, 122, 255, 0.08);
  border-radius: var(--radius-sm);
  padding: 6rpx 24rpx;
  margin-bottom: 12rpx;
  letter-spacing: 0.02em;
}

.modal-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background-color: rgba(52, 199, 89, 0.1);
  color: var(--green);
  font-size: 52rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.modal-buttons {
  display: flex;
  width: 100%;
  gap: 16rpx;
  margin-top: 32rpx;
}

.modal-half-btn {
  flex: 1;
  width: auto;
  padding: 22rpx 0;
  font-size: 26rpx;
}

/* ── v5: 附加服务参数卡 ── */
.ext-params-card {
  margin-bottom: 20rpx;
}

.param-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  gap: 16rpx;
  border-bottom: 0.5px solid var(--separator);
}
.param-row:last-child {
  border-bottom: none;
}

.param-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.param-unit {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.control-input {
  flex: 1;
  height: 56rpx;
  background: var(--gray6);
  border-radius: var(--radius-sm);
  padding: 0 14rpx;
  font-size: 24rpx;
  color: var(--text-primary);
}

/* Read-only glass display value (首页费等不可调参数) */
.param-value-glass {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.4);
  border: 1rpx solid rgba(60, 60, 67, 0.06);
  border-radius: var(--radius-sm);
  padding: 8rpx 16rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

/* iOS Toggle Switch */
.ios-switch {
  width: 88rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: rgba(60, 60, 67, 0.18);
  position: relative;
  transition: background 0.2s ease;
}
.ios-switch.switch-on {
  background: linear-gradient(180deg,
    rgba(52, 199, 89, 1) 0%,
    rgba(34, 180, 68, 1) 100%);
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.08);
}

/* 无障碍打印：加大 + 黄色主题 */
.ios-switch-lg {
  width: 108rpx;
  height: 62rpx;
  border-radius: 31rpx;
}
.ios-switch-lg.switch-on {
  background: linear-gradient(180deg,
    rgba(255, 149, 0, 0.85) 0%,
    rgba(230, 120, 0, 0.92) 100%);
}
.ios-switch-lg .switch-thumb {
  top: 3rpx;
  left: 4rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
}
.ios-switch.ios-switch-lg.switch-on .switch-thumb {
  transform: translateX(47rpx) !important;
}

.switch-thumb {
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg,
    rgba(255, 255, 255, 1) 0%,
    rgba(248, 248, 248, 0.95) 100%);
  box-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, 0.18),
    0 1rpx 3rpx rgba(0, 0, 0, 0.10),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.4s cubic-bezier(0.22, 1.85, 0.48, 1);
}
.ios-switch.switch-on .switch-thumb {
  transform: translateX(35rpx) !important;
}

.cover-price-tag {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-left: 12rpx;
  flex-shrink: 0;
}
.cover-price-tag.entering {
  animation: coverPriceIn 0.3s cubic-bezier(0.22, 0.61, 0.36, 1) both;
}
.cover-price-tag.exiting {
  animation: coverPriceOut 0.25s ease forwards;
}
@keyframes coverPriceIn {
  from { opacity: 0; transform: translateX(-16rpx); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes coverPriceOut {
  from { opacity: 1; transform: translateX(0); }
  to   { opacity: 0; transform: translateX(-16rpx); }
}

/* 自取地址折叠动画（与派送地点互斥，关闭派送时展开） */
.pickup-collapse {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.25s ease;
}
.pickup-collapse.pickup-open {
  max-height: 200rpx;
  opacity: 1;
}

/* 派送选项折叠动画 */
.delivery-collapse {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.25s ease;
}
.delivery-collapse.delivery-open {
  max-height: 200rpx;
  opacity: 1;
}

/* Picker trigger — glass chip */
.picker-trigger {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  background: rgba(255, 255, 255, 0.45);
  border: 1rpx solid rgba(60, 60, 67, 0.08);
  border-radius: var(--radius-sm);
  padding: 10rpx 16rpx;
  box-shadow:
    0 1rpx 4rpx rgba(0, 0, 0, 0.03),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
  transition: transform 0.1s ease, background-color 0.1s ease;
}
.picker-arrow {
  font-size: 28rpx;
  color: var(--text-quaternary);
}

/* Picker dropdown — animated expand/collapse */
.picker-sheet {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  background: var(--gray6);
  border-radius: var(--radius-md);
  padding: 0 4rpx;
  margin: 0 0 0 136rpx;
  transition: max-height 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
              opacity 0.25s cubic-bezier(0.25, 0.1, 0.25, 1),
              margin 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
              padding 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
}
.picker-sheet.picker-expanded {
  max-height: 500rpx;
  opacity: 1;
  padding: 4rpx;
  margin: 4rpx 0 8rpx 136rpx;
}
.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  border-radius: var(--radius-sm);
  font-weight: 500;
}
.picker-option:active {
  background: rgba(0, 122, 255, 0.08);
}
.picker-selected {
  background: var(--blue);
  color: #fff;
  font-weight: 600;
}
.picker-pct {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.picker-selected .picker-pct {
  color: rgba(255,255,255,0.8);
}

/* Urgency colors */
.urgency-high { color: var(--red) !important; font-weight: 600; }
