/**me.wxss**/

/* 根容器：填充剩余空间，建立 flex 列上下文 */
.page-root {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: #f5f5f5;
  min-height: 0;
}

/* 自定义滚动视口：吃掉导航条之外的剩余高度，自身不滚动 */
.scroller {
  flex: 1;
  overflow: hidden;
  position: relative;
  min-height: 0;
}

/* 滚动内容：靠 translateY 移动 */
.scroll-content {
  will-change: transform;
}

.container {
  padding: 24rpx 36rpx;
  padding-bottom: calc(120rpx + 40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-x: hidden;
  text-align: left;
}

/* 用户信息卡片 — 全宽 */
.user-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.avatar-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  padding: 0;
  margin: 0 24rpx 0 0;
  background: transparent;
  flex-shrink: 0;
  line-height: 1;
  overflow: hidden;
}

.avatar-hover {
  opacity: 0.7;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #e0e0e0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname-input {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  padding: 0;
  background: transparent;
  border: none;
  min-height: 44rpx;
  line-height: 44rpx;
  width: 100%;
}

.uid {
  font-size: 24rpx;
  color: #999;
}

/* 角色入口按钮 */
.role-actions {
  margin-bottom: 24rpx;
}

.role-btn {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 28rpx 30rpx;
  display: flex;
  align-items: center;
}

.role-btn-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.role-btn-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.role-btn-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.admin-btn {
  border-left: 6rpx solid #1677FF;
}

.user-btn {
  border-left: 6rpx solid #52c41a;
}

/* 任务区域 */
.orders-section {
  margin-top: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx 0 20rpx 12rpx;
  text-align: left;
}

.section-bar {
  width: 6rpx;
  height: 32rpx;
  background-color: #1677FF;
  border-radius: 3rpx;
  margin-right: 14rpx;
}

.order-count {
  margin-left: 12rpx;
  font-size: 22rpx;
  font-weight: normal;
  color: #fff;
  background-color: #1677FF;
  padding: 4rpx 14rpx;
  border-radius: 22rpx;
}

/* 状态提示 */
.status-box {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.status-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-illustration {
  width: 160rpx;
  height: 160rpx;
  background-color: #f0f5ff;
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* ==================== 任务卡片（可展开） ==================== */

.order-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  text-align: left;
  width: 100%;
  transition: box-shadow 0.25s, transform 0.2s;
}

.order-card:active {
  background-color: #fafafa;
}

.order-expanded {
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.order-card-header {
  /* contains collapsed view */
}

.order-card-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-filename {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 20rpx;
}

.order-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 22rpx;
  white-space: nowrap;
  font-weight: bold;
  flex-shrink: 0;
}

.status-queued { background-color: #fff7e6; color: #fa8c16; }
.status-printing { background-color: #e6f7ff; color: #1677FF; }
.status-sent { background-color: #f6ffed; color: #52c41a; }
.status-delivered { background-color: #f0fdf4; color: #15803d; }
.status-failed { background-color: #fff2f0; color: #ff4d4f; }
.status-canceled { background-color: #f5f5f5; color: #999; }

.order-card-meta {
  display: flex;
  gap: 30rpx;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.order-card-stat {
  display: inline-flex;
  align-items: center;
}

.order-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-created {
  font-size: 22rpx;
  color: #bbb;
}

.order-arrow {
  font-size: 32rpx;
  color: #ccc;
  transition: transform 0.25s;
  display: inline-block;
}

.arrow-up {
  transform: rotate(90deg);
  color: #1677FF;
}

/* ==================== 展开详情 ==================== */

.order-card-detail {
  animation: detailSlideIn 0.25s ease;
}

@keyframes detailSlideIn {
  from { opacity: 0; transform: translateY(-16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.detail-divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

.detail-section {
  margin-bottom: 24rpx;
}

.detail-section-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
}

.free-tag {
  color: #1677FF;
}

/* 文件列表行 */
.detail-file-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background-color: #f9fafb;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 10rpx;
}

.detail-file-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.detail-file-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.detail-file-tags {
  display: flex;
  gap: 10rpx;
}

.file-type-tag {
  font-size: 20rpx;
  color: #1677FF;
  background-color: #e6f4ff;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.file-size-tag {
  font-size: 20rpx;
  color: #999;
}

.detail-file-right {
  flex-shrink: 0;
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.detail-file-copies {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.detail-file-range {
  font-size: 20rpx;
  color: #fa8c16;
}

.file-status-mini {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 600;
}
.file-status-mini.status-queued { background-color: #fff7e6; color: #fa8c16; }
.file-status-mini.status-printing { background-color: #e6f7ff; color: #1677FF; }
.file-status-mini.status-sent { background-color: #f6ffed; color: #52c41a; }
.file-status-mini.status-failed { background-color: #fff2f0; color: #ff4d4f; }
.file-status-mini.status-canceled { background-color: #f5f5f5; color: #999; }

/* 展开态操作按钮 */
.detail-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 4rpx;
}

.btn-cancel-sm {
  width: 100%;
  background-color: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  font-size: 26rpx;
  border-radius: 18rpx;
  padding: 18rpx 0;
}

.btn-cancel-sm:active {
  background-color: #fff2f0;
}

/* ==================== 许可密钥区域 ==================== */

.license-section {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.license-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.license-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.license-stepper {
  margin-bottom: 24rpx;
}

/* 步进器（与 index.wxss 保持一致） */
.stepper {
  display: flex;
  align-items: center;
}

.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background-color: #f5f7fa;
  color: #333;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  line-height: 1;
}

.stepper-btn:active {
  background-color: rgba(22, 119, 255, 0.15);
}

.stepper-hover {
  background-color: rgba(22, 119, 255, 0.15) !important;
}

.stepper-disabled {
  color: #ccc;
}

.stepper-input {
  flex: 1;
  height: 72rpx;
  margin: 0 20rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  background-color: #fafafa;
  border-radius: 22rpx;
}

/* 密钥类型选择（超级管理员可见） */
.key-type-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.key-type-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.key-type-toggle {
  display: flex;
  background-color: #f5f7fa;
  border-radius: 22rpx;
  padding: 6rpx;
}

.key-type-option {
  padding: 14rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 18rpx;
  transition: all 0.2s;
}

.key-type-active {
  background-color: #1677FF;
  color: #fff;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.25);
}

/* 生成按钮 */
.generate-btn {
  width: 100%;
  background-color: #1677FF;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 22rpx;
  padding: 22rpx 0;
}

.generate-btn:active {
  background-color: #0958d9;
  opacity: 0.85;
}

/* ==================== 许可密钥抽屉（独立卡片，从生成卡片下方抽出） ==================== */

/* 抽屉容器：始终占位，用 max-height + transform 控制开合，弹簧曲线 */
.key-drawer {
  margin-top: 0;
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  position: relative;
  transition: max-height 0.32s cubic-bezier(0.34, 1.56, 0.64, 1),
              opacity 0.28s ease,
              margin-top 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 展开态（opening / open 共用） */
.key-drawer-show {
  max-height: 500rpx;   /* 容纳密钥 + 用户信息 + 按钮 */
  opacity: 1;
  margin-top: 16rpx;
}

/* 删除按钮：绝对定位在抽屉右侧底层，左滑时露出 */
.key-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  z-index: 0;
}

.key-delete:active {
  background-color: #d9363e;
}

/* 卡片本体：白底圆角，可左滑；盖在删除按钮之上 */
.key-drawer-inner {
  position: relative;
  z-index: 1;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 拖动中：关闭过渡，让位移跟手 */
.key-drawer-inner.no-transition {
  transition: none;
}

.key-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.key-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.key-right {
  margin-left: 20rpx;
}

.key-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.key-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1677FF;
  font-family: monospace;
  letter-spacing: 6rpx;
}

/* 倒计时：橙色等宽 */
.key-countdown {
  font-size: 30rpx;
  font-weight: bold;
  color: #fa8c16;
  font-family: monospace;
}

/* 抽屉下方操作区 */
.key-actions {
  display: flex;
  justify-content: flex-end;
}

/* 复制按钮（沿用原蓝系） */
.copy-btn {
  font-size: 24rpx;
  color: #1677FF;
  background-color: #e6f4ff;
  border-radius: 22rpx;
  padding: 12rpx 36rpx;
  margin: 0;
  border: 2rpx solid #91caff;
  line-height: 1.4;
}

.copy-btn:active {
  background-color: #bae0ff;
}

/* 已过期态：整体灰化 */
.key-drawer-expired .key-value {
  color: #bbb;
}

/* 已使用/锁定态：卡片蒙上灰色遮罩 */
.key-drawer-locked .key-drawer-inner {
  background-color: #fafafa;
  opacity: 0.75;
}

.key-drawer-locked .key-value {
  color: #999;
}

/* 临时授权倒计时 */
.temp-countdown {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #1677FF;
}

.countdown-expired {
  color: #bbb !important;
}

/* 复制按钮禁用态（已过期） */
.copy-btn-disabled {
  color: #bbb !important;
  background-color: #f5f5f5 !important;
  border-color: #e0e0e0 !important;
}

/* 等待任务中按钮（灰色不可点） */
.btn-waiting {
  color: #999 !important;
  background-color: #f5f5f5 !important;
  border-color: #e0e0e0 !important;
}

/* 结束打印任务按钮（橙红色警告态） */
.btn-end-task {
  color: #ff4d4f !important;
  background-color: #fff1f0 !important;
  border-color: #ffa39e !important;
}

/* 兑换用户信息 */
.key-user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
  padding: 14rpx 18rpx;
  background-color: #f6ffed;
  border-radius: 16rpx;
}

.key-user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.key-user-name {
  font-size: 26rpx;
  color: #52c41a;
  font-weight: bold;
}

/* 访客兑换区域 */
.redeem-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.redeem-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.redeem-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 22rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  text-transform: uppercase;
}

.redeem-btn {
  flex-shrink: 0;
  background-color: #1677FF;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 22rpx;
  padding: 22rpx 32rpx;
  margin: 0;
}

.redeem-btn:active {
  background-color: #0958d9;
}

/* ==================== 存储统计卡片 ==================== */

.storage-section {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.storage-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.storage-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.storage-row + .storage-row {
  border-top: 1rpx solid #f5f5f5;
  margin-top: 4rpx;
  padding-top: 16rpx;
}

.storage-label {
  font-size: 26rpx;
  color: #666;
}

.storage-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.storage-divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

.retention-title {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.retention-forever-hint {
  font-size: 22rpx;
  color: #fa8c16;
  display: block;
  margin-bottom: 12rpx;
}

/* 保留时间行：两个步进器 + 单位文字水平排列 */
.retention-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

/* 紧凑型步进器（比许可密钥 stepper 小） */
.retention-stepper {
  display: flex;
  align-items: center;
}

.retention-stepper-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background-color: #f5f7fa;
  color: #333;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  line-height: 1;
}

.retention-stepper-btn:active {
  background-color: rgba(22, 119, 255, 0.15);
}

.retention-stepper-btn.stepper-disabled {
  color: #ccc;
}

.retention-stepper-input {
  width: 80rpx;
  height: 56rpx;
  margin: 0 8rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  background-color: #fafafa;
  border-radius: 16rpx;
}

.retention-unit {
  font-size: 24rpx;
  color: #999;
  min-width: 48rpx;
}

/* 保存按钮 */
.retention-save-btn {
  width: 100%;
  background-color: #1677FF;
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 22rpx;
  padding: 18rpx 0;
  margin: 0;
}

.retention-save-btn:active {
  background-color: #0958d9;
  opacity: 0.85;
}

/* 已获得许可 */
.license-active {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 36rpx 30rpx;
}

.license-status-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.license-status-text {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: bold;
}

/* ==================== 许可用户列表 ==================== */

.users-section {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.user-item {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.user-licensed-at {
  font-size: 22rpx;
  color: #999;
}

/* 加载更多 */
.load-more-wrap {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.load-more-btn {
  background-color: #f5f7fa;
  color: #1677FF;
  font-size: 26rpx;
  border-radius: 22rpx;
  padding: 18rpx 48rpx;
  border: 2rpx solid #e8e8e8;
  margin: 0;
}

.load-more-btn:active {
  background-color: #e6f4ff;
}


/* 确认管理员按钮（绿色） */
.btn-confirm-admin {
  color: #52c41a !important;
  background-color: #f6ffed !important;
  border-color: #b7eb8f !important;
}

/* 管理员卡片 */
.admin-card-wrap {
  position: relative;
  margin-bottom: 16rpx;
}

.admin-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  z-index: 0;
}

.admin-delete:active {
  background-color: #d9363e;
}

.admin-card {
  position: relative;
  z-index: 1;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.admin-card.admin-swipe-trans {
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.admin-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.admin-avatar-placeholder {
  background-color: #e8e8e8;
}

.admin-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.admin-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.admin-badge {
  font-size: 22rpx;
  color: #1677FF;
  background-color: #e6f4ff;
  border-radius: 12rpx;
  padding: 4rpx 14rpx;
}
