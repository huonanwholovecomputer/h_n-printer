/**order-detail.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  height: 0;
}

.container {
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

/* 加载 & 空状态 */
.loading-box, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 详情卡片 */
.detail-card {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.status-bar {
  padding: 30rpx 30rpx 0;
}

.status-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 22rpx;
  font-weight: bold;
}

.status-queued { background-color: #fff7e6; color: #fa8c16; }
.status-printing { background-color: #e6f7ff; color: #1677FF; }
.status-sent { background-color: #f6ffed; color: #52c41a; }
.status-failed { background-color: #fff2f0; color: #ff4d4f; }
.status-canceled { background-color: #f5f5f5; color: #999; }

/* 信息组 */
.info-group {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-group:last-of-type {
  border-bottom: none;
}

.info-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 文件列表卡片 */
.detail-file-card {
  background-color: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 12rpx;
}

.detail-file-card:last-child {
  margin-bottom: 0;
}

.detail-file-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.detail-file-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.status-tag-mini {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 18rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.status-tag-mini.status-queued { background-color: #fff7e6; color: #fa8c16; }
.status-tag-mini.status-printing { background-color: #e6f7ff; color: #1677FF; }
.status-tag-mini.status-sent { background-color: #f6ffed; color: #52c41a; }
.status-tag-mini.status-failed { background-color: #fff2f0; color: #ff4d4f; }
.status-tag-mini.status-canceled { background-color: #f5f5f5; color: #999; }

.detail-file-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 22rpx;
  color: #aaa;
}

/* 操作按钮 */
.action-bar {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-cancel {
  width: 100%;
  background-color: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  font-size: 30rpx;
  border-radius: 22rpx;
  padding: 22rpx 0;
}

.btn-cancel:active {
  background-color: #fff2f0;
}

.cancel-hover {
  background-color: #fff2f0 !important;
}

.btn-reprint {
  width: 100%;
  background-color: #1677FF;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 22rpx;
  padding: 22rpx 0;
}

.btn-reprint:active {
  background-color: #0958d9;
  opacity: 0.85;
}

.reprint-hover {
  background-color: #0958d9 !important;
  opacity: 0.85;
}
