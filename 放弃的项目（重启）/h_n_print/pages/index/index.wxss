/**index.wxss**/

/* 根容器：填充剩余空间，建立 flex 列上下文 */
.page-root {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: #f5f5f5;
  min-height: 0;
}

/* 自定义滚动视口：吃掉导航条之外的剩余高度，自身不滚动 */
.scroller {
  flex: 1;
  overflow: hidden;
  position: relative;
  min-height: 0;
}

/* 滚动内容：靠 translateY 移动，will-fix 优化合成层 */
.scroll-content {
  will-change: transform;
}

.container {
  padding: 30rpx;
  padding-bottom: 0;
  box-sizing: border-box;
  transition: width 0.3s ease;
}

.announcement {
  text-align: center;
  padding: 40rpx 0;
  transition: padding 0.06s linear;
}

.logo-wrap {
  display: inline-block;
  transition: transform 0.06s linear;
}

.logo {
  width: 400rpx;
}

/* 打印机状态指示器 */
.printer-status {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 30rpx;
  font-size: 24rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 7rpx;
  margin-right: 10rpx;
}

.status-active {
  color: #1677FF;
}

.status-active .status-dot {
  background-color: #1677FF;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%   { box-shadow: 0 0 0 0 rgba(22, 119, 255, 0.5); }
  70%  { box-shadow: 0 0 0 8rpx rgba(22, 119, 255, 0); }
  100% { box-shadow: 0 0 0 0 rgba(22, 119, 255, 0); }
}

.status-inactive {
  color: #999;
}

.status-inactive .status-dot {
  background-color: #bbb;
}

/* 表单区域 */
.order-form {
  margin-top: 20rpx;
  width: 100%;
  box-sizing: border-box;
  /* 防止子元素撑宽父容器 */
  overflow: hidden;
}

.form-item {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.form-item:nth-child(1) { animation: cardIn 0.3s ease 0.05s both; }
.form-item:nth-child(2) { animation: cardIn 0.3s ease 0.12s both; }
.form-item:nth-child(3) { animation: cardIn 0.3s ease 0.19s both; }

@keyframes cardIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.form-label {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 20rpx;
}

/* ---- 文件列表容器 ---- */
.file-list-container {
  padding-bottom: 20rpx;
}

.file-list-container .form-label {
  border-bottom: 1rpx solid #e8e8e8;
  padding-bottom: 18rpx;
}

/* 文件卡片：入场时从 0 高度展开 */
.file-card {
  background-color: #f9fafb;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  transition: width 0.3s ease;
}

/* 仅新增卡片播放入场动画，避免列表更新时全部重播 */
.file-card-entering {
  animation: fileCardEnter 0.38s cubic-bezier(0.25, 0.1, 0.25, 1);
}

@keyframes fileCardEnter {
  from {
    max-height: 0;
    margin-bottom: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
  }
  to {
    max-height: 2000rpx;
    margin-bottom: 16rpx;
    padding-top: 22rpx;
    padding-bottom: 22rpx;
    opacity: 1;
  }
}

/* 退场：前 65% 纯淡化+微缩（GPU，不触发布局），后 35% 快速折叠空间 */
.file-card-exit {
  animation: fileCardExit 0.3s ease forwards;
  pointer-events: none;
}

@keyframes fileCardExit {
  0% {
    opacity: 1;
    max-height: 2000rpx;
    margin-bottom: 16rpx;
    padding-top: 22rpx;
    padding-bottom: 22rpx;
  }
  65% {
    opacity: 0;
    max-height: 2000rpx;
    margin-bottom: 16rpx;
    padding-top: 22rpx;
    padding-bottom: 22rpx;
  }
  100% {
    opacity: 0;
    max-height: 0;
    margin-bottom: 0;
    padding-top: 0;
    padding-bottom: 0;
  }
}

.file-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.file-name {
  flex: 1;
  min-width: 0;
}

.file-name-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size-text {
  display: block;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.file-remove-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background-color: #eee;
  color: #999;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.remove-hover {
  background-color: #ff4d4f !important;
  color: #fff !important;
}

/* 每个文件的上传状态 */
.file-upload-status {
  margin-top: 16rpx;
  min-height: 28rpx;
}

/* 每文件份数行 */
.file-copies-row {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.file-copies-label {
  font-size: 26rpx;
  color: #888;
  margin-right: 20rpx;
}

.file-stepper {
  flex: 1;
}

.file-stepper .stepper-input {
  height: 60rpx;
  font-size: 28rpx;
}

.file-stepper .stepper-btn {
  width: 60rpx;
  height: 60rpx;
  font-size: 30rpx;
}

/* 每文件打印范围 */
.file-page-range-row {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.file-page-range-label {
  font-size: 26rpx;
  color: #888;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.file-page-range-input {
  flex: 1;
  height: 56rpx;
  font-size: 24rpx;
  color: #333;
  background-color: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 14rpx;
  padding: 0 16rpx;
}

.file-page-range-input::placeholder {
  color: #ccc;
}

/* 每文件双面打印行 */
.file-duplex-row {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.file-duplex-label {
  font-size: 26rpx;
  color: #888;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 文件卡片内的双面选择器（缩小版） */
.file-duplex-picker {
  flex: 1;
  border-radius: 16rpx;
  background-color: #F0F2F5;
}

.file-duplex-picker .duplex-slider {
  top: 3rpx;
  left: 3rpx;
  width: calc(50% - 3rpx);
  height: calc(100% - 6rpx);
  border-radius: 14rpx;
}

.file-duplex-picker .duplex-option {
  padding: 12rpx 0;
  font-size: 24rpx;
}


/* Excel 文件禁用态 */
.excel-disabled-row {
  opacity: 0.45;
  pointer-events: none;
}

/* 添加文件按钮 */
.add-file-btn {
  width: 100%;
  background-color: #e8f2ff;
  color: #1677FF;
  font-size: 28rpx;
  border-radius: 22rpx;
  padding: 24rpx;
  text-align: center;
  border: 2rpx dashed #d0d5dd;
  box-shadow: 0 4rpx 14rpx rgba(22, 119, 255, 0.12);
  transition: transform 0.1s ease, background-color 0.15s ease, box-shadow 0.15s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.add-file-btn:active {
  background-color: rgba(22, 119, 255, 0.15);
  transform: scale(0.97);
  box-shadow: 0 1rpx 4rpx rgba(22, 119, 255, 0.08);
}

.tap-active {
  background-color: rgba(22, 119, 255, 0.15) !important;
  transform: scale(0.97) !important;
  box-shadow: 0 1rpx 4rpx rgba(22, 119, 255, 0.08) !important;
}

.add-file-icon {
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 文件上传进度条 */
.upload-progress {
  margin-top: 20rpx;
  animation: fadeSlideIn 0.2s ease;
}

.upload-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.upload-status-text {
  font-size: 26rpx;
  font-weight: 500;
}

.upload-status-text.uploading {
  color: #1677FF;
}

.upload-status-text.done {
  color: #52c41a;
}

.upload-status-text.failed {
  color: #ff4d4f;
  font-size: 24rpx;
}

.upload-status-text.warn {
  color: #d48806;
  font-size: 22rpx;
}

.upload-percent {
  font-size: 24rpx;
  color: #1677FF;
  font-variant-numeric: tabular-nums;
}

/* 进度条轨道 */
.progress-track {
  width: 100%;
  height: 12rpx;
  background-color: #f0f2f5;
  border-radius: 6rpx;
  overflow: hidden;
}

/* 进度条填充：宽度由 JS 控制，transition 让两次取样之间平滑过渡 */
.progress-fill {
  height: 100%;
  background-color: #1677FF;
  border-radius: 6rpx;
  /* transition 持续时间略大于取样间隔(0.5s)，确保跨取样点也连续 */
  transition: width 0.5s ease-out;
}

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
}

.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background-color: #f5f7fa;
  color: #333;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  line-height: 1;
  transition: background-color 0.2s ease;
}

.stepper-btn:active {
  background-color: rgba(22, 119, 255, 0.15);
}

.stepper-hover {
  background-color: rgba(22, 119, 255, 0.15) !important;
}

.stepper-disabled {
  color: #ccc;
}

.stepper-input {
  flex: 1;
  height: 72rpx;
  margin: 0 20rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  background-color: #fafafa;
  border-radius: 22rpx;
}

/* 单双面选择器 */
.duplex-picker {
  position: relative;
  display: flex;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #F0F2F5;
}

/* 滑动背景块 */
.duplex-slider {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: calc(50% - 4rpx);
  height: calc(100% - 8rpx);
  border-radius: 22rpx;
  background-color: #1677FF;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.duplex-slider.slider-right {
  transform: translateX(100%);
}

.duplex-option {
  flex: 1;
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 28rpx;
  color: #666;
  transition: color 0.3s;
}

.duplex-active {
  color: #fff;
  font-weight: 600;
}

/* 提交按钮：位于滚动流中，随内容自然滚动 */
.submit-bar {
  padding: 20rpx 0;
  padding-bottom: calc(120rpx + 40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  width: 100%;
}

.submit-btn {
  width: 100%;
  background-color: #1677FF;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 22rpx;
  padding: 24rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.25);
  transition: transform 0.1s ease, background-color 0.15s ease, box-shadow 0.15s ease;
}

.submit-btn:active {
  background-color: #0958d9;
  transform: scale(0.97);
}

.submit-hover {
  background-color: #0958d9 !important;
  transform: scale(0.97) !important;
}

/* 成功弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

.modal-card {
  width: 560rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slideUp 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx) scale(0.95); }
  to   { opacity: 1; transform: translateY(0)     scale(1);    }
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  width: 100%;
  gap: 20rpx;
}

.modal-btn-cancel {
  flex: 1;
  background-color: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 22rpx;
  padding: 22rpx 0;
}

.modal-btn-cancel:active {
  background-color: #e0e0e0;
}

.modal-btn-confirm {
  flex: 1;
  background-color: #1677FF;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 22rpx;
  padding: 22rpx 0;
}

.modal-btn-confirm:active {
  background-color: #0958d9;
  opacity: 0.85;
}
