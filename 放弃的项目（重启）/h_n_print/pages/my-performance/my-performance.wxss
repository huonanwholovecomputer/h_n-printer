/* my-performance.wxss */
.container {
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

/* 月份选择器 */
.date-picker {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.picker-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.picker-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.picker-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1677FF;
  padding: 10rpx 30rpx;
  background: #F0F5FF;
  border-radius: 22rpx;
}

/* 状态提示 */
.status-box {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 统计卡片网格 */
.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #1677FF;
  margin-bottom: 10rpx;
}

.card-label {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #999;
}
