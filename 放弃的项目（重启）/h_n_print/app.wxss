/**app.wxss**/

/* 让 page 高度撑满视口，建立 flex 列上下文，后续子元素用 flex 分配高度 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 全局点击反馈 — hover-class 对短按/长按均生效 */
.tap-active {
  opacity: 0.7;
}
