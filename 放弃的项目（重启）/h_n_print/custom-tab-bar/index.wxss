/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  display: flex;
  align-items: center;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 4rpx;
}

/* 手指按下时的即时反馈 */
.tab-hover {
  opacity: 0.65;
}

/* 图标容器 — 激活时加灰色底纹（像按钮按下） */
.tab-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
  transition: background-color 0.2s;
}

.icon-active {
  background-color: #F0F0F0;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 文字 */
.tab-text {
  font-size: 20rpx;
  color: #999;
}

.text-active {
  color: #1677FF;
  font-weight: 600;
}
